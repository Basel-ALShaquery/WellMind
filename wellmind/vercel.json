{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/mood/stats", "destination": "/api/mood/stats" },
    { "source": "/api/mood",       "destination": "/api/mood" },
    { "source": "/api/bookings",   "destination": "/api/bookings" },
    { "source": "/api/chat",       "destination": "/api/chat" },
    { "source": "/(.*)",           "destination": "/index.html" }
  ]
}
